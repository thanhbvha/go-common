# Set default behavior to automatically normalize line endings
* text=auto

# Force LF line endings for Go source files, module configurations, and metadata
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.gitignore text eol=lf
.gitattributes text eol=lf

# Keep binary files as-is without any normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.dll binary
